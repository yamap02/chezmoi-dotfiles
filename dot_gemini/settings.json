{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "sandbox": {
      "enabled": true,
      "network": {
        "mode": "allowlist",
        "allowedHosts": [
          "github.com",
          "*.github.com",
          "objects.githubusercontent.com",
          "raw.githubusercontent.com",
          "registry.npmjs.org",
          "api.anthropic.com",
          "api.github.com",
          "*.vercel.com",
          "*.supabase.co",
          "localhost",
          "127.0.0.1",
          "<your-container-registry>",
          "<your-package-registry>",
          "<your-internal-api>"
        ]
      },
      "filesystem": {
        "denyRead": [
          "**/.env*",
          "**/secrets*",
          "**/*.key",
          "**/*.pem",
          "**/.ssh/*",
          "**/.aws/*",
          "**/.gnupg/*",
          "**/*_rsa",
          "**/*_ed25519",
          "**/*_dsa",
          "**/credentials",
          "~/Documents",
          "~/Documents/**",
          "/Users/user/Documents",
          "/Users/user/Documents/**",
          "~/Downloads",
          "~/Downloads/**",
          "/Users/user/Downloads",
          "/Users/user/Downloads/**",
          "~/Library",
          "~/Library/**",
          "/Users/user/Library",
          "/Users/user/Library/**"
        ],
        "denyWrite": [
          "**/.env*",
          "~/Documents",
          "~/Documents/**",
          "/Users/user/Documents",
          "/Users/user/Documents/**",
          "~/Downloads",
          "~/Downloads/**",
          "/Users/user/Downloads",
          "/Users/user/Downloads/**",
          "~/Library",
          "~/Library/**",
          "/Users/user/Library",
          "/Users/user/Library/**"
        ]
      }
    },
    "shellCommandAllowlist": [
      "curl http://localhost*",
      "curl http://127.0.0.1*",
      "wget http://localhost*",
      "wget http://127.0.0.1*",
      "nc localhost*",
      "nc 127.0.0.1*",
      "docker ps *",
      "docker compose up *"
    ],
    "shellCommandDenylist": [
      "rm -rf",
      "sudo",
      "git push --force",
      "brew",
      "env",
      "printenv",
      "osascript",
      "crontab",
      "ssh",
      "scp",
      "ncat"
    ]
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "ui": {
    "theme": "Default",
    "hideTips": true,
    "showMemoryUsage": true
  },
  "general": {
    "vimMode": true,
    "defaultApprovalMode": "default",
    "enableNotifications": true,
    "plan": {
      "directory": "",
      "modelRouting": true
    }
  },
  "model": {
    "name": ""
  }
}
