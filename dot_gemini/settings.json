{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "sandbox": {
      "enabled": true,
      "network": {
        "mode": "allowlist",
        "allowedHosts": [
          "github.com",
          "*.github.com",
          "api.github.com",
          "objects.githubusercontent.com",
          "raw.githubusercontent.com",

          "registry.npmjs.org",

          "api.anthropic.com",

          "vercel.com",
          "api.vercel.com",
          "*.vercel.com",

          "supabase.co",
          "api.supabase.co",
          "*.supabase.co",

          "localhost",
          "127.0.0.1"
        ]
      },
      "filesystem": {
        "denyRead": [
          "**/.env*",
          "**/secrets*",
          "**/credentials",

          "**/*.key",
          "**/*.pem",
          "**/*_rsa",
          "**/*_ed25519",
          "**/*_dsa",

          "**/.ssh/*",
          "**/.aws/*",
          "**/.gnupg/*",
          "**/.npmrc",
          "**/.netrc",
          "**/.pypirc",
          "**/.docker/config.json",

          "~/Documents",
          "~/Documents/**",
          "/Users/user/Documents",
          "/Users/user/Documents/**",

          "~/Downloads",
          "~/Downloads/**",
          "/Users/user/Downloads",
          "/Users/user/Downloads/**",

          "~/Library",
          "~/Library/**",
          "/Users/user/Library",
          "/Users/user/Library/**"
        ],
        "denyWrite": [
          "**/.env*",

          "~/Documents",
          "~/Documents/**",
          "/Users/user/Documents",
          "/Users/user/Documents/**",

          "~/Downloads",
          "~/Downloads/**",
          "/Users/user/Downloads",
          "/Users/user/Downloads/**",

          "~/Library",
          "~/Library/**",
          "/Users/user/Library",
          "/Users/user/Library/**"
        ]
      }
    },
    "shellCommandAllowlist": [
      "curl http://localhost*",
      "curl http://127.0.0.1*",
      "wget http://localhost*",
      "wget http://127.0.0.1*",
      "nc localhost*",
      "nc 127.0.0.1*",

      "npm run lint",
      "npm run lint:*",
      "npm run test",
      "npm run test:*",
      "npm run build",
      "npm run build:*",
      "npm run typecheck",

      "pnpm lint",
      "pnpm test",
      "pnpm test:*",
      "pnpm -w test:*",
      "pnpm build",
      "pnpm typecheck",

      "yarn lint",
      "yarn test",
      "yarn build",

      "docker ps *",
      "docker compose up *"
    ],
      "shellCommandDenylist": [
        "rm -rf",
        "sudo",
        "brew",
        "env",
        "printenv",
        "osascript",
        "crontab",
        "ssh",
        "scp",
        "ncat",
      "launchctl",
      "defaults write",
      "chmod +s",
      "history",

      "npm install -g",
      "pip install",
      "pip3 install",

      "git config --global",
      "git config --system",
      "git remote add",
      "git credential",
      "git push --force",
      "git push -f",
      "gh auth"
    ]
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "ui": {
    "theme": "Default",
    "hideTips": true,
    "showMemoryUsage": true
  },
  "general": {
    "vimMode": true,
    "defaultApprovalMode": "default",
    "enableNotifications": true,
    "plan": {
      "directory": "",
      "modelRouting": true
    }
  },
  "model": {
    "name": ""
  }
}
